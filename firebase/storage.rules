rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /patients/{patientId}/{allPaths=**} {
      allow read: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/patients/$(patientId)/members/$(request.auth.uid));
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/patients/$(patientId)/members/$(request.auth.uid)).data.role in ['admin', 'editor'] &&
        request.resource.size < 10 * 1024 * 1024; // 10MB max
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024; // 5MB max
    }
  }
}
