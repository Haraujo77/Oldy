rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function memberRole(patientId) {
      return get(/databases/$(database)/documents/patients/$(patientId)/members/$(request.auth.uid)).data.role;
    }

    function isMember(patientId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/patients/$(patientId)/members/$(request.auth.uid));
    }

    function isAdmin(patientId) {
      return isMember(patientId) && memberRole(patientId) == 'admin';
    }

    function isEditor(patientId) {
      return isMember(patientId) && memberRole(patientId) in ['admin', 'editor'];
    }

    function isCreator(patientId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/patients/$(patientId)).data.createdBy == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Patients collection
    match /patients/{patientId} {
      allow read: if isMember(patientId) ||
        (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin(patientId) ||
        (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin(patientId);

      // Members subcollection
      match /members/{memberId} {
        allow read: if isMember(patientId) ||
          (isAuthenticated() && memberId == request.auth.uid);
        allow create: if isAdmin(patientId) ||
          (isAuthenticated() && memberId == request.auth.uid);
        allow update, delete: if isAdmin(patientId);
      }

      // Health plans (patients/{patientId}/plans/health/metrics/{metricType})
      match /plans/health/metrics/{metricType} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow write: if isAdmin(patientId) || isCreator(patientId);
      }

      // Medication plans (patients/{patientId}/plans/meds/items/{itemId})
      match /plans/meds/items/{itemId} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow write: if isAdmin(patientId) || isCreator(patientId);
      }

      // Health logs (patients/{patientId}/health_logs/{logId})
      match /health_logs/{logId} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow create: if isEditor(patientId) || isCreator(patientId);
        allow update: if isEditor(patientId) || isCreator(patientId);
        allow delete: if isAdmin(patientId) || isCreator(patientId);
      }

      // Medication dose events (patients/{patientId}/logs/meds/events/{eventId})
      match /logs/meds/events/{eventId} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow create: if isEditor(patientId) || isCreator(patientId);
        allow update: if isEditor(patientId) || isCreator(patientId);
        allow delete: if isAdmin(patientId) || isCreator(patientId);
      }

      // Activity posts (patients/{patientId}/logs/activities/posts/{postId})
      match /logs/activities/posts/{postId} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow create: if isEditor(patientId) || isCreator(patientId);
        allow update: if isEditor(patientId) || isCreator(patientId);
        allow delete: if isAdmin(patientId) || isCreator(patientId);

        // Comments subcollection
        match /comments/{commentId} {
          allow read: if isMember(patientId) || isCreator(patientId);
          allow create: if isMember(patientId) || isCreator(patientId);
          allow update: if isAuthenticated() && request.auth.uid == resource.data.createdBy;
          allow delete: if isAdmin(patientId) || isCreator(patientId) ||
            (isAuthenticated() && request.auth.uid == resource.data.createdBy);
        }
      }

      // Clinical exams (patients/{patientId}/exams/{examId})
      match /exams/{examId} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow create: if isEditor(patientId) || isCreator(patientId);
        allow update: if isEditor(patientId) || isCreator(patientId);
        allow delete: if isAdmin(patientId) || isCreator(patientId);
      }

      // Catch-all for any other subcollections under patients
      match /{path=**} {
        allow read: if isMember(patientId) || isCreator(patientId);
        allow write: if isEditor(patientId) || isCreator(patientId);
      }

      // Invites
      match /invites/{inviteId} {
        allow read: if isMember(patientId) || isCreator(patientId) ||
          resource.data.email == request.auth.token.email;
        allow create: if isAdmin(patientId) || isCreator(patientId);
        allow update: if isAdmin(patientId) || isCreator(patientId) ||
          resource.data.email == request.auth.token.email;
        allow delete: if isAdmin(patientId) || isCreator(patientId);
      }
    }

    // Collection group rule for invites (needed for acceptInvite lookup by code)
    match /{path=**}/invites/{inviteId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Global medication catalog (read-only for clients)
    match /medCatalog/{medicationId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
